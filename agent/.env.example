# LLM Access
AI_GATEWAY_API_KEY=

# Braintrust eval platform (required to run evals)
BRAINTRUST_API_KEY=
PROJECT_NAME=openemr-ai-agent

# Research API from Pubmed
PUBMED_API_KEY=

# OpenEMR API Access (OAuth2 password grant)
# Run scripts/prod-register-oauth-client.sh to generate client_id + client_secret
OPENEMR_BASE_URL=https://your-prod-domain.com
OPENEMR_CLIENT_ID=
OPENEMR_CLIENT_SECRET=
OPENEMR_USERNAME=admin
OPENEMR_PASSWORD=

# OpenEMR Direct DB Access (used by insuranceCoverageTool)
# On Railway: use the internal hostname of the MySQL service
OPENEMR_DB_HOST=
OPENEMR_DB_PORT=3306
OPENEMR_DB_USER=openemr
OPENEMR_DB_PASSWORD=
OPENEMR_DB_NAME=openemr

# Agent server config
PORT=3001
# Comma-separated list of allowed CORS origins (set to your production OpenEMR URL)
CORS_ORIGIN=https://your-prod-domain.com
